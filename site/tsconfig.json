{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "strict": false,
    "paths": {
      "ngx-tethys": ["../src/public-api"],
      "ngx-tethys/*": ["../src/*"],
      "@tethys/cdk": ["../cdk/public-api"],
      "@tethys/cdk/*": ["../cdk/*"],
      "@pc-nexus/ng-uikit": ["../projects/ng-uikit/public-api.ts"],
      "@pc-nexus/ng-uikit/*": ["../projects/ng-uikit/*"]
    }
  },
  "angularCompilerOptions": {
    "skipLibCheck": true,
    "enableI18nLegacyMessageIdFormat": false,
    "strictStandalone": false,
    "strictInjectionParameters": false,
    "strictInputAccessModifiers": false,
    "strictTemplates": false
  }
}
