{
  "name": "ngx-tethys",
  "version": "21.0.4",
  "license": "MIT",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0",
    "pnpm": ">=9.0.0",
    "npm": "Please use pnpm instead of npm to install dependencies",
    "yarn": "Please use pnpm instead of yarn to install dependencies"
  },
  "scripts": {
    "ng": "ng",
    "start": "docgeni serve --configuration development",
    "serve": "docgeni serve --configuration development",
    "build:demo": "pnpm run build-site",
    "build:site": "pnpm run build-site",
    "build-site": "pnpm run build-docs && ng build site --configuration production --base-href=/ngx-tethys/",
    "build-clean-site": "pnpm run build-docs && ng build site --configuration production",
    "build-docs": "docgeni build --skip-site --progress false",
    "build": "pnpm run build-cdk && pnpm run build-tethys && pnpm run build:schematics",
    "build-tethys": "rimraf ./dist/tethys/* && node --max-old-space-size=8096 ./node_modules/@angular/cli/bin/ng build ngx-tethys --configuration production && pnpm run copy-md && pnpm run build-testing",
    "build-styles": "cpx \"./src/**/*.scss\" dist/tethys",
    "copy-md": "cpx \"./README.md\" dist/tethys && cpx \"./CHANGELOG.md\" dist/tethys",
    "build-testing": "cpx \"./src/core/testing/**/*.ts\" ./dist/tethys/core/testing",
    "build-cdk": "ng build cdk --configuration production",
    "release-only": "wpm release",
    "release": "wpm release --release-branch-format release-auto-v{{version}}",
    "release-next": "wpm release --release-branch-format release-auto-next-v{{version}}",
    "release-manual": "wpm release",
    "release-next-manual": "wpm release --release-branch-format release-next-v{{version}}",
    "admin-release": "wpm release --skip.branch --skip.push",
    "pub-only": "pnpm run pub-tethys-only && pnpm run pub-cdk-only",
    "pub-cdk-only": "cd dist/cdk && pnpm publish",
    "pub-tethys-only": "cd dist/tethys && pnpm publish",
    "pub": "wpm publish && pnpm run pub-only",
    "pub-next-only": "pnpm run pub-next-tethys-only && pnpm run pub-next-cdk-only",
    "pub-next-cdk-only": "cd ./dist/cdk && pnpm publish --tag next",
    "pub-next-tethys-only": "cd ./dist/tethys && pnpm publish --tag next",
    "pub-next": "wpm publish && pnpm run pub-next-only",
    "test": "pnpm run test-tethys && pnpm run test-schematics",
    "test-tethys": "ng test ngx-tethys",
    "test-cdk": "ng test cdk",
    "report-coverage": "cat ./coverage/tethys/lcov.info | coveralls",
    "lint": "ng lint ngx-tethys && node --max-old-space-size=8096 ./node_modules/@angular/cli/bin/ng lint cdk",
    "lint-fix": "node --max-old-space-size=8096 ./node_modules/@angular/cli/bin/ng lint cdk --fix && ng lint ngx-tethys --fix",
    "pretty": "pretty-quick --staged",
    "e2e": "ng e2e",
    "serve-demo": "http-server dist/site -p 8888 -g &",
    "build:schematics": "tsc -p ./schematics && pnpm run copy:schematics",
    "copy:schematics": "cpx \"./schematics/**/*.{json,template}\" ./dist/tethys/schematics/ -v",
    "test-schematics": "pnpm run build:schematics && node ./node_modules/jasmine/bin/jasmine './dist/tethys/schematics/**/*.spec.js'",
    "// test-schematics": "TS_NODE_PROJECT=./schematics/tsconfig.json node --require ts-node/register/transpile-only ./node_modules/jasmine/bin/jasmine './schematics/**/*.spec.ts'",
    "prettier-all": "prettier --write \"./src/**/*.ts\"",
    "prettier-schematics": "prettier --write \"./schematics/**/*.ts\"",
    "prepublishOnly": "./scripts/pre-publish.js",
    "extract-css-varibales": "node ./scripts/extract-css-variables.js"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/atinc/ngx-tethys.git"
  },
  "description": "Angular UI Components",
  "keywords": [
    "Angular",
    "Angular 2+"
  ],
  "dependencies": {
    "@angular/animations": "^22.0.2",
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/platform-server": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@angular/ssr": "^22.0.3",
    "@ngx-translate/core": "^15.0.0",
    "date-fns": "4.1.0",
    "rxjs": "~7.8.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "^22.0.3",
    "@angular-devkit/schematics": "^22.0.3",
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/build": "^22.0.3",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.2",
    "@angular/language-service": "^22.0.2",
    "@commitlint/cli": "^16.2.3",
    "@commitlint/config-angular": "^18.6.1",
    "@date-fns/tz": "1.2.0",
    "@docgeni/cli": "2.8.0-next.7",
    "@docgeni/template": "2.8.0-next.7",
    "@schematics/angular": "^22.0.3",
    "@tethys/icons": "1.4.89",
    "@types/highlight.js": "^9.12.4",
    "@types/jasmine": "~2.8.6",
    "@types/express": "^5.0.1",
    "@types/node": "^22.3.0",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "@worktile/pkg-manager": "^0.2.0-next.4",
    "chalk": "^2.4.2",
    "concurrently": "^3.6.0",
    "coveralls": "^3.1.1",
    "cpx": "^1.5.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "fs-extra": "^8.0.1",
    "http-server": "^14.1.1",
    "jasmine": "~4.0.0",
    "jasmine-core": "~4.0.0",
    "karma": "^6.3.4",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.1.0",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.3.3",
    "prettier-eslint": "^16.3.0",
    "pretty-quick": "~4.0.0",
    "prismjs": "1.30.0",
    "docsearch.js": "2.6.3",
    "rimraf": "^6.1.3",
    "readline-sync": "^1.4.9",
    "replace": "^1.1.0",
    "semver": "^7.5.2",
    "ts-node": "~10.9.1",
    "typescript": "~6.0.3",
    "@eslint/js": "^9.23.0",
    "@eslint/markdown": "^7.0.0",
    "eslint-plugin-header": "~3.1.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^51.0.0",
    "eslint-plugin-prefer-arrow": "~1.2.2",
    "eslint-plugin-unused-imports": "^4.1.4",
    "angular-eslint": "^22.0.0",
    "typescript-eslint": "^8.37.0"
  }
}
